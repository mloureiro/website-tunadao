---
/**
 * HierarchyPyramid - Hierarchical pyramid with increasing widths from top to bottom
 * Each level has a distinct color and tier badge
 */
import { useTranslations, type Language } from '@i18n/index';
import SectionDivider from '@components/SectionDivider.astro';

interface Props {
  title: string;
  intro: string;
  dividerLabel: string;
  lang: Language;
}

const { title, intro, dividerLabel, lang } = Astro.props;
const t = useTranslations(lang);

const levels = [
  {
    titleKey: 'about.hierarchy.tunoMestre',
    descKey: 'about.hierarchy.tunoMestreDesc',
    tier: 1,
  },
  {
    titleKey: 'about.hierarchy.tunosIlustres',
    descKey: 'about.hierarchy.tunosIlustresDesc',
    tier: 2,
  },
  {
    titleKey: 'about.hierarchy.tunosDoutores',
    descKey: 'about.hierarchy.tunosDoutoresDesc',
    tier: 3,
  },
  {
    titleKey: 'about.hierarchy.tunos',
    descKey: 'about.hierarchy.tunosDesc',
    tier: 4,
  },
  {
    titleKey: 'about.hierarchy.caloiros',
    descKey: 'about.hierarchy.caloirosDesc',
    tier: 5,
  },
  {
    titleKey: 'about.hierarchy.aprendizes',
    descKey: 'about.hierarchy.aprendizesDesc',
    tier: 6,
  },
] as const;
---

<section class="hierarchy">
  <div class="container">
    <SectionDivider label={dividerLabel} centered />
    <h2 class="hierarchy__title">{title}</h2>
    <p class="hierarchy__intro">{intro}</p>

    <div class="hierarchy__pyramid" role="list" aria-label={title}>
      {levels.map((level) => (
        <div
          role="listitem"
          class="hierarchy__level"
          data-tier={level.tier}
        >
          <div class="hierarchy__card">
            <h3 class="hierarchy__card-title">
              {t(level.titleKey)}
            </h3>
            <p class="hierarchy__card-desc">
              {t(level.descKey)}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hierarchy {
    padding: var(--space-16) 0;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-background) 100%);
  }

  .hierarchy__title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hierarchy__title {
      font-size: var(--font-size-4xl);
    }
  }

  .hierarchy__intro {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 42rem;
    margin: 0 auto var(--space-12);
  }

  @media (min-width: 768px) {
    .hierarchy__intro {
      font-size: var(--font-size-lg);
    }
  }

  .hierarchy__pyramid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hierarchy__level {
    width: 100%;
    transition: all var(--transition-slow);
  }

  /* Per-tier max-width (pyramid shape) */
  .hierarchy__level[data-tier="1"] { max-width: 24rem; }
  .hierarchy__level[data-tier="2"] { max-width: 28rem; }
  .hierarchy__level[data-tier="3"] { max-width: 32rem; }
  .hierarchy__level[data-tier="4"] { max-width: 36rem; }
  .hierarchy__level[data-tier="5"] { max-width: 42rem; }
  .hierarchy__level[data-tier="6"] { max-width: 48rem; }

  .hierarchy__level:hover {
    transform: translateY(-2px);
  }

  .hierarchy__card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    padding: var(--space-5) var(--space-6);
    box-shadow: var(--shadow-lg);
    transition: box-shadow var(--transition-slow);
  }

  .hierarchy__card:hover {
    box-shadow: var(--shadow-xl);
  }

  /* Per-tier card background colors */
  .hierarchy__level[data-tier="1"] .hierarchy__card { background: var(--color-accent-gold); }
  .hierarchy__level[data-tier="2"] .hierarchy__card { background: var(--color-primary); }
  .hierarchy__level[data-tier="3"] .hierarchy__card { background: var(--color-primary-dark); }
  .hierarchy__level[data-tier="4"] .hierarchy__card { background: var(--color-secondary-dark); }
  .hierarchy__level[data-tier="5"] .hierarchy__card { background: var(--color-secondary); }
  .hierarchy__level[data-tier="6"] .hierarchy__card { background: var(--color-neutral-600); }

  /* Per-tier text colors — all tiers use inverted (white); tier 3 uses a subtle tint */
  .hierarchy__card-title,
  .hierarchy__card-desc {
    color: var(--color-text-inverted);
  }

  .hierarchy__level[data-tier="3"] .hierarchy__card-title,
  .hierarchy__level[data-tier="3"] .hierarchy__card-desc {
    color: color-mix(in srgb, var(--color-text-inverted) 94%, var(--color-primary));
  }

  .hierarchy__card-title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-1);
  }

  @media (min-width: 768px) {
    .hierarchy__card-title {
      font-size: var(--font-size-xl);
    }
  }

  .hierarchy__card-desc {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .hierarchy__card-desc {
      font-size: var(--font-size-base);
    }
  }
</style>
