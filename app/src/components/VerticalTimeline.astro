---
import { Icon as AstroIcon } from 'astro-icon/components';
import { useTranslations, type Language, defaultLang } from '@i18n/index';

/**
 * VerticalTimeline - Modern vertical year navigation
 * Displays years as a vertical timeline with scroll-based tracking
 * Desktop: Fixed sidebar on the left
 * Mobile: Floating year indicator
 */
interface Props {
  years: number[];
  /** CSS class prefix for year section IDs (e.g., "year" for id="year-2024") */
  idPrefix?: string;
  /** Label for screen readers */
  ariaLabel?: string;
  /** CSS selector for the section that scopes timeline visibility */
  sectionSelector?: string;
  /** Active language for localized aria-labels */
  lang?: Language;
}

const {
  years,
  idPrefix = 'year',
  ariaLabel = 'Jump to year',
  sectionSelector,
  lang = defaultLang,
} = Astro.props;
const t = useTranslations(lang);

// Sort years descending (most recent first)
const sortedYears = [...years].sort((a, b) => b - a);
---

<!-- Desktop: Vertical sidebar timeline -->
<nav
  class="vertical-timeline"
  aria-label={ariaLabel}
  data-id-prefix={idPrefix}
  data-section-selector={sectionSelector}
>
  <div class="vertical-timeline__track">
    <div class="vertical-timeline__line" aria-hidden="true"></div>
    <ul class="vertical-timeline__list" role="list">
      {
        sortedYears.map((year, index) => {
          const gradientPos = sortedYears.length > 1 ? index / (sortedYears.length - 1) : 0;

          return (
            <li class="vertical-timeline__item" style={`--t: ${gradientPos};`}>
              <a
                href={`#${idPrefix}-${year}`}
                class="vertical-timeline__link"
                data-year={year}
                aria-label={t('common.jumpToYearN', { year })}
              >
                <span class="vertical-timeline__dot" aria-hidden="true" />
                <span class="vertical-timeline__label">{year}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<!-- Mobile: Floating year indicator -->
<div class="year-indicator" aria-hidden="true">
  <button class="year-indicator__button" type="button" aria-label={t('palmares.currentYearNav')}>
    <span class="year-indicator__text"></span>
    <AstroIcon name="lucide:chevron-down" class:list={['year-indicator__icon']} size={16} />
  </button>
  <div class="year-indicator__dropdown">
    <ul class="year-indicator__list" role="list">
      {
        sortedYears.map((year) => (
          <li>
            <a href={`#${idPrefix}-${year}`} class="year-indicator__dropdown-link" data-year={year}>
              {year}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  (function () {
    function initVerticalTimeline() {
      const navEl = document.querySelector('.vertical-timeline');
      if (!navEl) return;
      const nav = navEl as HTMLElement;
      const indicator = document.querySelector('.year-indicator');
      const indicatorText = indicator?.querySelector('.year-indicator__text');
      const indicatorButton = indicator?.querySelector('.year-indicator__button');
      const dropdown = indicator?.querySelector('.year-indicator__dropdown');

      const idPrefix = nav.getAttribute('data-id-prefix') || 'year';

      // Get all year links and sections
      const yearLinks = nav.querySelectorAll('.vertical-timeline__link');
      const dropdownLinks = indicator?.querySelectorAll('.year-indicator__dropdown-link');
      const yearSections: Element[] = [];

      yearLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href) {
          const section = document.querySelector(href);
          if (section) yearSections.push(section);
        }
      });

      if (yearSections.length === 0) return;

      // Section scoping
      const sectionSelector = nav.getAttribute('data-section-selector');
      const scopeSection = sectionSelector ? document.querySelector(sectionSelector) : null;

      // Track current year
      let currentYear: string | null = null;

      function updateActiveYear(year: string) {
        if (year === currentYear) return;
        currentYear = year;

        // Update timeline
        yearLinks.forEach((link) => {
          const linkYear = link.getAttribute('data-year');
          const isActive = linkYear === year;
          link.classList.toggle('vertical-timeline__link--active', isActive);
          link.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        // Update indicator
        if (indicatorText) {
          indicatorText.textContent = year;
        }

        // Update dropdown links
        dropdownLinks?.forEach((link) => {
          const linkYear = link.getAttribute('data-year');
          link.classList.toggle('year-indicator__dropdown-link--active', linkYear === year);
        });
      }

      // Intersection Observer for tracking current year
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries.filter((e) => e.isIntersecting);

          if (visibleEntries.length > 0) {
            visibleEntries.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

            const topSection = visibleEntries[0].target;
            const year = topSection.id.replace(new RegExp(`^${idPrefix}-`), '');
            updateActiveYear(year);
          }
        },
        {
          rootMargin: '-20% 0px -60% 0px',
          threshold: 0,
        }
      );

      yearSections.forEach((section) => observer.observe(section));

      // Show/hide based on scoped section visibility
      if (scopeSection) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            const isVisible = entries[0].isIntersecting;
            indicator?.classList.toggle('year-indicator--visible', isVisible);
            nav.classList.toggle('vertical-timeline--active', isVisible);
            if (isVisible) {
              updateTimelinePosition();
            } else {
              nav.style.top = '';
              nav.style.transform = '';
            }
          },
          { threshold: 0 }
        );

        sectionObserver.observe(scopeSection);

        // Clamp timeline position within section bounds
        function updateTimelinePosition() {
          if (!nav.classList.contains('vertical-timeline--active')) return;

          const sectionRect = scopeSection!.getBoundingClientRect();
          const timelineHeight = nav.offsetHeight || 200;
          const viewportCenter = window.innerHeight / 2;

          // Ideal: centered in viewport
          const idealTop = viewportCenter - timelineHeight / 2;

          // Clamp to section bounds
          const clampedTop = Math.max(
            sectionRect.top,
            Math.min(idealTop, sectionRect.bottom - timelineHeight)
          );

          nav.style.top = clampedTop + 'px';
          nav.style.transform = 'none';
        }

        window.addEventListener('scroll', updateTimelinePosition, { passive: true });
        window.addEventListener('resize', updateTimelinePosition, { passive: true });
      } else {
        // Fallback: original behavior (show when first section scrolls past)
        const showObserver = new IntersectionObserver(
          (entries) => {
            const isNavVisible = entries[0].isIntersecting;
            indicator?.classList.toggle('year-indicator--visible', !isNavVisible);
            nav.classList.toggle('vertical-timeline--active', !isNavVisible);
          },
          { threshold: 0.5 }
        );

        if (yearSections[0]) {
          showObserver.observe(yearSections[0]);
        }
      }

      // Smooth scroll for timeline links
      function handleLinkClick(e: Event) {
        e.preventDefault();
        const link = e.currentTarget as HTMLElement;
        const href = link.getAttribute('href');
        if (!href) return;

        const target = document.querySelector(href);
        if (!target) return;

        // Close dropdown if open
        dropdown?.classList.remove('year-indicator__dropdown--open');

        const offset = 100;
        const targetPosition = target.getBoundingClientRect().top + window.scrollY - offset;

        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth',
        });
      }

      yearLinks.forEach((link) => link.addEventListener('click', handleLinkClick));
      dropdownLinks?.forEach((link) => link.addEventListener('click', handleLinkClick));

      // Toggle dropdown
      indicatorButton?.addEventListener('click', () => {
        dropdown?.classList.toggle('year-indicator__dropdown--open');
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!indicator?.contains(e.target as Node)) {
          dropdown?.classList.remove('year-indicator__dropdown--open');
        }
      });

      // Keyboard navigation for timeline
      nav.addEventListener('keydown', (event) => {
        const e = event as KeyboardEvent;
        const links = Array.from(yearLinks);
        const currentIndex = links.findIndex((link) => link === document.activeElement);

        if (currentIndex === -1) return;

        let nextIndex = currentIndex;

        switch (e.key) {
          case 'ArrowDown':
          case 'ArrowRight':
            e.preventDefault();
            nextIndex = Math.min(currentIndex + 1, links.length - 1);
            break;
          case 'ArrowUp':
          case 'ArrowLeft':
            e.preventDefault();
            nextIndex = Math.max(currentIndex - 1, 0);
            break;
          case 'Home':
            e.preventDefault();
            nextIndex = 0;
            break;
          case 'End':
            e.preventDefault();
            nextIndex = links.length - 1;
            break;
        }

        if (nextIndex !== currentIndex) {
          (links[nextIndex] as HTMLElement).focus();
        }
      });

      // Set initial state
      if (yearSections[0]) {
        const firstYear = yearSections[0].id.replace(new RegExp(`^${idPrefix}-`), '');
        updateActiveYear(firstYear);
        if (indicatorText) indicatorText.textContent = firstYear;
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initVerticalTimeline);
    } else {
      initVerticalTimeline();
    }
  })();
</script>

<style>
  /* Desktop Vertical Timeline */
  .vertical-timeline {
    display: none;
    position: fixed;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .vertical-timeline--active {
    opacity: 1;
    pointer-events: auto;
  }

  /* NOTE: intentional off-scale keep. 1200px is the mobile↔desktop-sidebar boundary;
     snapping to 1024/1280 would move a real layout boundary (visible regression).
     See wiki/website-tunadao-zmo5. */
  @media (min-width: 1200px) {
    .vertical-timeline {
      display: block;
    }
  }

  .vertical-timeline__track {
    position: relative;
    padding: var(--space-4) 0;
  }

  .vertical-timeline__line {
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 2px;
    z-index: 0;
    background: linear-gradient(to bottom, var(--color-primary), var(--color-accent-gold));
  }

  .vertical-timeline__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .vertical-timeline__item {
    --dot-color: color-mix(
      in srgb,
      var(--color-primary),
      var(--color-accent-gold) calc(var(--t) * 100%)
    );
    margin: 0;
  }

  .vertical-timeline__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-2) var(--space-1) 0;
    text-decoration: none;
    transition: all var(--transition-fast);
    border-radius: var(--radius-md);
  }

  .vertical-timeline__link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .vertical-timeline__dot {
    position: relative;
    z-index: 1;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: var(--dot-color);
    border: 2px solid color-mix(in srgb, var(--dot-color) 70%, white);
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .vertical-timeline__label {
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .vertical-timeline__link:hover .vertical-timeline__dot,
  .vertical-timeline__link:focus-visible .vertical-timeline__dot {
    transform: scale(1.15);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
  }

  .vertical-timeline__link:hover .vertical-timeline__label,
  .vertical-timeline__link:focus-visible .vertical-timeline__label {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-text);
  }

  .vertical-timeline__link--active .vertical-timeline__dot {
    transform: scale(1.3);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.15);
  }

  .vertical-timeline__link--active .vertical-timeline__label {
    opacity: 1;
    transform: translateX(0);
    font-weight: 600;
    color: var(--dot-color);
  }

  /* Mobile Year Indicator */
  .year-indicator {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 50;
    opacity: 0;
    transform: translateY(10px);
    transition: all var(--transition-base);
    pointer-events: none;
  }

  .year-indicator--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* NOTE: intentional off-scale keep. 1200px is the mobile↔desktop-sidebar boundary;
     snapping to 1024/1280 would move a real layout boundary (visible regression).
     See wiki/website-tunadao-zmo5. */
  @media (min-width: 1200px) {
    .year-indicator {
      display: none;
    }
  }

  .year-indicator__button {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background-color: var(--color-primary);
    color: var(--color-text-inverted);
    border: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--font-size-lg);
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    transition: all var(--transition-fast);
  }

  .year-indicator__button:hover {
    background-color: var(--color-primary-dark);
    transform: scale(1.05);
  }

  .year-indicator__button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }

  .year-indicator__icon {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .year-indicator:has(.year-indicator__dropdown--open) .year-indicator__icon {
    transform: rotate(180deg);
  }

  .year-indicator__dropdown {
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: var(--space-2);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    max-height: 300px;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all var(--transition-fast);
  }

  .year-indicator__dropdown--open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .year-indicator__list {
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .year-indicator__dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    text-align: center;
    min-width: 80px;
  }

  .year-indicator__dropdown-link:hover {
    background-color: var(--color-surface-hover);
  }

  .year-indicator__dropdown-link--active {
    background-color: var(--color-primary);
    color: var(--color-text-inverted);
  }

  @media (max-width: 640px) {
    .year-indicator {
      bottom: var(--space-4);
      right: var(--space-4);
    }

    .year-indicator__button {
      padding: var(--space-2) var(--space-3);
      font-size: var(--font-size-base);
    }
  }
</style>
