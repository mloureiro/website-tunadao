# PayloadCMS API URL used at build time (and astro dev). Default: http://localhost:3000
CMS_URL=http://localhost:3000

# Client-readable CMS base URL for the contact form POST (distinct from the build-time `CMS_URL`).
# This is inlined into the client bundle by Astro. Must be set in the production build env.
PUBLIC_CMS_URL=http://localhost:3000

# Force static fixtures instead of hitting the CMS (used by E2E). Default: false
USE_TEST_FIXTURES=false

# Require a live CMS at build time; fail the build if unreachable. Default: false
FORCE_PROD_CMS=false
