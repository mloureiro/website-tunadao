{
  "name": "tunadao-cms",
  "version": "1.0.0",
  "description": "CMS for Tunadao 1998 website",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8000 next build",
    "start": "next start",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "payload": "payload",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "seed": "tsx src/seed/index.ts",
    "provision:admin": "tsx src/seed/provision-admin.ts",
    "db:reset": "tsx src/seed/reset-db.ts",
    "db:reset-and-seed": "tsx src/seed/reset-db.ts && payload migrate && tsx src/seed/index.ts",
    "db:export": "tsx src/export/index.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check:env": "node scripts/check-env-parity.mjs",
    "migrate:check": "node scripts/check-migration-drift.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.73.0",
    "@payloadcms/email-resend": "^3.73.0",
    "@payloadcms/next": "^3.73.0",
    "@payloadcms/richtext-lexical": "^3.73.0",
    "@payloadcms/ui": "^3.73.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "graphql": "^16.8.1",
    "next": "^15.4.10",
    "payload": "^3.73.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.4.7",
    "prettier": "^3.8.1",
    "sass": "^1.77.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
